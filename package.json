{
  "name": "breadcrumb-protocol",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.0",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm -r build",
    "check": "corepack pnpm -r --workspace-concurrency=1 check",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck",
    "smoke": "corepack pnpm --filter @adikuma/breadcrumb smoke"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
